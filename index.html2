<!DOCTYPE html>
<html>
<head>
<title>Nahmir Store</title>
<style>
body{
font-family: Arial;
background:#0f172a;
color:white;
text-align:center;
}

.box{
background:#1e293b;
margin:20px;
padding:20px;
border-radius:10px;
}

button{
padding:10px 20px;
background:#22c55e;
border:none;
color:white;
border-radius:5px;
}
</style>
</head>

<body>

<h1>🔥 Nahmir Store</h1>
<p>Cheap OTT Subscriptions & Digital Services</p>

<div class="box">
<h2>Spotify Lifetime</h2>
<p>Price: ₹800</p>
</div>

<div class="box">
<h2>Gemini AI Pro</h2>
<p>Price: ₹399 (12 Months)</p>
</div>

<div class="box">
<h2>Amazon Prime</h2>
<p>Price: ₹130</p>
</div>

<div class="box">
<h2>Payment</h2>
<p>UPI / Crypto Accepted</p>
</div>

<div class="box">
<h2>Support</h2>
<p>Telegram: @nahmirstore</p>
</div>

</body>
</html>
